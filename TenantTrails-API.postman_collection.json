              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jordan Lee\",\n  \"email\": \"jordan@dal.ca\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json; charset=utf-8"
            }
          ],
          "cookie": [],
          "body": "{\"user\":{\"id\":5,\"name\":\"Jordan Lee\",\"email\":\"jordan@dal.ca\"},\"token\":\"<jwt>\"}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const d = pm.response.json();",
              "if (d.token) pm.collectionVariables.set('token', d.token);",
              "pm.test('status ok', () => pm.expect([200,201]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
